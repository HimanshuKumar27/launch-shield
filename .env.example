# LaunchShield — Vercel Environment Variables
# ──────────────────────────────────────────────
# Copy these to your Vercel project settings:
#   Project → Settings → Environment Variables
#
# REQUIRED: Firebase service account JSON (for rate limiting via Firestore)
# Paste the ENTIRE contents of your service account JSON file as a single-line string.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# OPTIONAL: Google PageSpeed Insights API key
# Without this, LaunchShield uses deterministic mock scoring.
# Get yours free at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# OPTIONAL: Gemini AI API key (for real AI recommendations)
# Without this, LaunchShield uses rule-based fallback recommendations.
# Get yours free at: https://aistudio.google.com/
GEMINI_API_KEY=

# OPTIONAL: ScreenshotOne API key (for higher-quality screenshots)
# Without this, LaunchShield uses the free Microlink fallback.
# Get yours at: https://screenshotone.com/ (100 free/month)
SCREENSHOT_API_KEY=
